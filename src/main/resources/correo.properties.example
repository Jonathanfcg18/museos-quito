# Plantilla de configuración SMTP — HU-10 / HU-11 (Correo Service).
#
# Copia este archivo como "correo.properties" (mismo directorio) y completa
# tus credenciales para desarrollo local. "correo.properties" está en
# .gitignore y NUNCA debe subirse al repositorio con credenciales reales.
#
# En producción (Railway u otro), en lugar de este archivo, define las
# variables de entorno equivalentes — igual que DATABASE_URL en
# HibernateUtil — y CorreoService las usará automáticamente con prioridad
# sobre este archivo:
#   SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS, SMTP_FROM
#
# Si usas Gmail: NO uses tu contraseña normal de la cuenta. Gmail requiere
# una "Contraseña de aplicación" (App Password) generada desde la
# configuración de seguridad de tu cuenta de Google, con la verificación en
# dos pasos activada.

correo.smtp.host=smtp.gmail.com
correo.smtp.port=587
correo.smtp.usuario=tu_correo@gmail.com
correo.smtp.password=tu_app_password_de_16_caracteres
# Opcional: remitente visible si es distinto al usuario SMTP.
correo.smtp.from=tu_correo@gmail.com
